generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int     @id @default(autoincrement())
  email     String? @unique
  username  String? @unique
  name      String?
  firstName String?
  lastName  String?
  role      Role    @default(STUDENT)
  settings  Json?
  tools     Tool[]
}

model Tool {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  category    Category
  url         String
  source      String?
  description String?
  emoji       String?
  icon        String?
  authors     User[]
}

model Redirect {
  id        Int    @id @default(autoincrement())
  shortName String @unique
  name      String
  url       String
}

model Channel {
  id          Int       @id @default(autoincrement())
  title       String    @unique
  description String
  createdAt   DateTime  @default(now())
  messages    Message[]
}

model Message {
  id        Int       @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime  @default(now())
  publishAt DateTime?
  expiresAt DateTime?
  channel   Channel   @relation(fields: [channelId], references: [id])
  channelId Int
  buttons   Json[]
}

model Course {
  uid       String    @id
  type      String?
  summary   String?
  startDate DateTime?
  endDate   DateTime?
  teachers  String[]
  location  String?
  module    String?
}

model Module {
  id          String @id
  celcatID    String @unique
  name        String
  shortName   String
  emoji       String
  description String
  tasks       Task[]
}

model Action {
  id           Int        @id @default(autoincrement())
  actionType   ActionType
  actionTarget String
  createdAt    DateTime   @default(now())
}

model Task {
  id          Int       @id @default(autoincrement())
  module      Module    @relation(fields: [moduleId], references: [id])
  moduleId    String
  title       String
  description String?
  groups      Group[]
  files       Json[]
  expected    Json[]
  date        DateTime?
  deadline    DateTime?
}

enum Group {
  // Roles
  ALL

  STUDENT
  CONTRIBUTOR
  MANAGER
  ADMIN

  // Groupes
  MMI1_A1
  MMI1_A2
  MMI1_B1
  MMI1_B2
  MMI2_A1
  MMI2_A2
  MMI2_B1
  MMI2_B2
  MMI3_DW_FA_A1
  MMI3_DW_FA_A2
  MMI3_CN_FA_A1
  MMI3_CN_FA_A2
  MMI3_CN_FI_A1
  MMI3_CN_FI_A2
}

enum Role {
  STUDENT // Niveau le plus bas, accès aux infos du style IP minecraft, planning, etc
  CONTRIBUTOR // Peut ajouter des outils uniquement
  MANAGER // Peut gérer les outils et publier des messages
  ADMIN // Niveau le plus haut, accès à toutes les fonctionnalités
}

enum ActionType {
  LOAD
  TOOL
  MESSAGE
  LINK
}

enum Category {
  STUDENTS
  OFFICIAL
  RESOURCE
}
